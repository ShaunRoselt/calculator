  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ShaunRoselt/calculator/issues"
  },
  "homepage": "https://github.com/ShaunRoselt/calculator#readme",
  "private": true,
  "dependencies": {
    "nerdamer": "^1.1.13"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "electron": "^35.7.5"
  }
}
