{
  "name": "calculator",
  "version": "12.0.0",
  "description": "A standalone web calculator with standard, scientific, programmer, graphing, date, and unit conversion modes.",
  "main": "electron/main.cjs",
  "scripts": {
    "check": "node scripts/check.js",
    "package:win": "electron-packager . Calculator --platform=win32 --arch=x64 --out=dist --overwrite --asar --prune=true",
    "start": "python3 -m http.server 4173",
    "start:desktop": "electron ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShaunRoselt/calculator.git"
  },
  "keywords": [],
